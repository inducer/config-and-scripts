// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "search": {
    "regex": true
  },
  "languages": {
    "Python": {
      "preferred_line_length": 88
    }
  },
  "ui_font_weight": 400.0,
  "inlay_hints": {
    "enabled": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "format_on_save": "off",
  "edit_predictions": {
    "mode": "subtle"
  },
  "autosave": "on_focus_change",
  "buffer_line_height": "standard",
  "session": {
    "restore_unsaved_buffers": false
  },
  "buffer_font_family": "IosevkaTermSlab Nerd Font",
  "helix_mode": true,
  "agent": {
    "tool_permissions": {
      "tools": {
        "edit_file": {
          "default": "allow"
        }
      }
    },
    "default_model": {
      "provider": "openrouter",
      "model": "z-ai/glm-5.1",
      "enable_thinking": true
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "openai/gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "z-ai/glm-5.1",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 17.0,
  "buffer_font_size": 15.5,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé",
  },
  // Works with https://github.com/Else00/zed-jinja-universal
  "file_types": {
    "YAML-Jinja": ["*.yml", "*.yaml"]
  }
}
