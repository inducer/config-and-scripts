#! /bin/bash

if test "$1" = ""; then
	DATE="$(date "+%Y-%m-%d")"
else
	DATE="$1"
fi
shift

grab-procare-pics \
	--procare-key="$(cat ~/.procare-api-key )" \
	grab "$DATE"

source ~/src/current-env/bin/activate
immichpy assets upload --show-progress --album-name "Adi Kita" ~/nc/shared/cbal/kiddo/procare-pics
