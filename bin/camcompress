#! /bin/bash

set -eo pipefail

TGTDIR="comp"
mkdir -p "$TGTDIR"
count=1
for i in *.[jJ][pP][gG] ; do
    if test -f "$i"; then
        echo "$count: $i"
        outfile="$TGTDIR/${i%%.[jJ][pP][gG]}.heic"
        heif-enc "$i" -o "$outfile"
        MN="$(echo "binary maker notes, base64 of gzip, newlines are ^: " && exiftool -MakerNotes "$i" -b |gzip -c | base64 | tr '\n' '^' )"
        # https://github.com/immich-app/immich/issues/29766
        exiftool -overwrite_original -MakerNotes= "-UserComment=$MN" "$outfile"
        count=$((count+1))
    fi
done

find . -iname '*.mp4' -print0 | \
    parallel -j1 -0 "mkdir -p $CAMTMPDIR/{//}; ffmpeg -i {} -c:v libx264 -preset slow -map_metadata 0 -crf 25 -b:a 64k $TGTDIR/{}"

echo "compressed files are in comp/"

# vim: sw=4
