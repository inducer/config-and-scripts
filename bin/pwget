#!/usr/bin/env bash
# Provides an interactive CLI interface to browse Bitwarden/rbw vault entries
# and copy either the password or the username of a selected entry to the system
# clipboard. 

# wait for window shape to settle
sleep 0.2

# Dependencies check
for cmd in rbw jq sk; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Error: Required command '$cmd' is not installed."
        exit 1
    fi
done

# Detect clipboard tool
if command -v wl-copy &> /dev/null; then
    CLIPPER="wl-copy"
elif command -v xclip &> /dev/null; then
    CLIPPER="xclip -selection clipboard"
else
    echo "Error: No clipboard tool found (install xclip or wl-clipboard)"
    exit 1
fi

selection=$( \
    rbw list --raw  \
    | jq -r '.[] | "\(.name) [Password] ::: \(.user) ::: \(.id) ::: pass", "\(.name) [Username] ::: \(.user) ::: \(.id) ::: user"'  \
    | sk)

if [ -z "$selection" ]; then
    exit 0
fi

# Extract parts using awk
# Format: Display ::: User/Value ::: ID ::: Action
username_value=$(echo "$selection" | awk -F ' ::: ' '{print $2}')
target_id=$(echo "$selection" | awk -F ' ::: ' '{print $3}')
action_type=$(echo "$selection" | awk -F ' ::: ' '{print $4}')

if [ "$action_type" == "pass" ]; then
    rbw get "$target_id" | $CLIPPER
    echo "Password copied."
elif [ "$action_type" == "user" ]; then
    echo "$username_value" | $CLIPPER
    echo "Username copied."
fi
