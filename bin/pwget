#!/usr/bin/env -S uv run --script
#
# /// script
# dependencies = [
#   "urwid",
#   "pyperclip",
#   "pydantic",
# ]
# ///

"""
Password List Viewer - rbw TUI frontend (Urwid version)

Lists all passwords from `rbw list --raw`, provides a fuzzy search box,
and allows copying the password or username of the selected entry.
"""

import json
import subprocess
import sys
from typing import Any, Literal

import urwid
from pydantic import BaseModel, Field, model_validator
from pyperclip import copy as clipboard_copy


class PasswordEntry(BaseModel):
    """Representation of an rbw password entry."""
    id: str
    name: str
    user: str | None = None
    folder: str | None = None
    uris: list[str] = Field(default_factory=list)
    type: Literal["Login", "Card", "Identity", "Note"]

    @model_validator(mode="before")
    @classmethod
    def normalize_uris(cls, data: Any) -> Any:
        if isinstance(data, dict) and data.get("uris") is None:
            data["uris"] = []
        return data


def get_raw_list() -> list[PasswordEntry]:
    """Run `rbw list --raw` and return the parsed JSON list as Pydantic models."""
    try:
        result = subprocess.run(
            ["rbw", "list", "--raw"],
            capture_output=True,
            text=True,
            check=True,
        )
    except subprocess.CalledProcessError as e:
        print(f"Error running rbw list: {e.stderr}", file=sys.stderr)
        sys.exit(1)
    except FileNotFoundError:
        print("rbw not found. Please install rbw first.", file=sys.stderr)
        sys.exit(1)

    try:
        data = json.loads(result.stdout)
        return [PasswordEntry.model_validate(entry) for entry in data]
    except (json.JSONDecodeError, ValueError) as e:
        print(f"Invalid data from rbw: {e}", file=sys.stderr)
        sys.exit(1)


def get_password(uuid: str) -> str:
    """Run `rbw get UUID` and return the password."""
    try:
        result = subprocess.run(
            ["rbw", "get", uuid],
            capture_output=True,
            text=True,
            check=True,
        )
    except subprocess.CalledProcessError:
        # In a TUI, we might want to display this error better,
        # but for now we'll just return empty.
        return ""
    return result.stdout.rstrip("\n")


def fuzzy_match(query: str, entry: PasswordEntry) -> bool:
    """Check if `query` is a case-insensitive substring of any relevant field."""
    q = query.lower()
    name = entry.name.lower()
    user = (entry.user or "").lower()
    uris = " ".join(entry.uris).lower()
    return q in name or q in user or q in uris


class PasswordButton(urwid.Button):
    """Custom button to store the entry data."""
    def __init__(self, entry: PasswordEntry, callback):
        self.entry = entry
        label = f"{entry.name} ({entry.user})" if entry.user else entry.name
        super().__init__(label, on_press=callback)


class PasswordApp:
    def __init__(self):
        self.all_entries = get_raw_list()
        self.filtered_entries = list(self.all_entries)

        # UI Elements
        self.search_edit = urwid.Edit(("caption", "Search: "))
        self.list_walker = urwid.SimpleFocusListWalker([])
        self.list_box = urwid.ListBox(self.list_walker)

        # Header and Footer
        header = urwid.AttrWrap(self.search_edit, "editbx")
        footer_text = [
            ("key", "ENTER"), " copy pass  ",
            ("key", "CTRL+U"), " copy user  ",
            ("key", "ESC/Q"), " quit",
        ]
        footer = urwid.AttrWrap(urwid.Text(footer_text), "footer")

        # Layout
        self.view = urwid.Frame(
            body=urwid.AttrWrap(self.list_box, "body"),
            header=header,
            footer=footer
        )

        # Palette
        self.palette = [
            ("body", "default", "default"),
            ("footer", "black", "light gray"),
            ("key", "light cyan", "light gray", "bold"),
            ("editbx", "light gray", "dark blue"),
            ("selected", "black", "yellow"),
        ]

        # Signals
        urwid.connect_signal(self.search_edit, "change", self.on_search_change)

        self.update_list()

    def update_list(self):
        widgets = []
        for entry in self.filtered_entries:
            btn = PasswordButton(entry, self.on_item_selected)
            widgets.append(urwid.AttrWrap(btn, "body", "selected"))

        self.list_walker[:] = widgets
        if widgets:
            self.list_box.set_focus(0)

    def on_search_change(self, widget, query):
        self.filtered_entries = [
            e for e in self.all_entries if fuzzy_match(query, e)
        ]
        self.update_list()

    def on_item_selected(self, button):
        self.copy_password(button.entry)

    def copy_password(self, entry: PasswordEntry):
        password = get_password(entry.id)
        if password:
            clipboard_copy(password)
            self.show_overlay(f"Copied password for {entry.name}")

    def copy_username(self):
        focus_widget, _ = self.list_box.get_focus()
        if focus_widget:
            entry = focus_widget.base_widget.entry
            if entry.user:
                clipboard_copy(entry.user)
                self.show_overlay(f"Copied username: {entry.user}")
            else:
                self.show_overlay("No username for this entry")

    def show_overlay(self, message):
        """Briefly show a message overlay."""
        text = urwid.Text(f"\n {message} \n", align="center")
        fill = urwid.Filler(urwid.LineBox(text))
        overlay = urwid.Overlay(
            fill, self.view,
            "center", ("relative", 60),
            "middle", ("relative", 20)
        )

        def remove_overlay(loop, data):
            loop.widget = self.view

        self.loop.widget = overlay
        self.loop.set_alarm_in(1.5, remove_overlay)

    def unhandled_input(self, key):
        if key in ("q", "Q", "esc"):
            raise urwid.ExitMainLoop()
        if key == "ctrl u":
            self.copy_username()
        if key == "down" and self.view.focus_position == "header":
            self.view.focus_position = "body"
        if key == "up" and self.view.focus_position == "body" and self.list_box.get_focus()[1] == 0:
            self.view.focus_position = "header"

    def run(self):
        self.loop = urwid.MainLoop(
            self.view,
            self.palette,
            unhandled_input=self.unhandled_input
        )
        self.loop.run()


if __name__ == "__main__":
    app = PasswordApp()
    app.run()
