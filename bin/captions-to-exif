#!/usr/bin/env python3
import argparse
import html
import re
import subprocess
import warnings
from dataclasses import dataclass
from datetime import datetime, timedelta
from pathlib import Path
from zoneinfo import ZoneInfo


@dataclass
class ImageMetadata:
    filename: str
    date: datetime | None
    caption: str


def run_exiftool(args: list[str]):
    return subprocess.run(
        ["exiftool", *args], capture_output=True, text=True, check=True
    ).stdout


def parse_captions(path: Path, tz: ZoneInfo) -> list[ImageMetadata]:
    metadata_list: list[ImageMetadata] = []

    # Pattern: filename [YYYY-MM-DD] [HH:MM] caption
    # Date and Time are optional (no literal brackets in input)
    line_pattern = re.compile(
        r"^(\S+)(?:\s+(\d{4}-\d{2}-\d{2}))?(?:\s+(\d{2}:\d{2}))?\s+(.*)$"
    )

    with open(path, encoding="utf-8") as f:
        for line_num, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue

            match = line_pattern.match(line)
            if not match:
                warnings.warn(  # noqa: B028
                    f"Line {line_num}: Does not match expected format. Ignoring."
                )
                continue

            fname, date_str, time_str, caption = match.groups()

            # Convert HTML entities in caption
            caption = html.unescape(caption)

            dt = None
            if date_str:
                # If time is missing, default to noon
                t_str = time_str if time_str else "12:00"
                dt = datetime.strptime(f"{date_str} {t_str}", "%Y-%m-%d %H:%M").replace(tzinfo=tz)

            metadata_list.append(
                ImageMetadata(filename=fname, date=dt, caption=caption)
            )

    return metadata_list


def main():
    parser = argparse.ArgumentParser(description="Convert captions.txt to EXIF tags.")
    parser.add_argument(
        "source_dir", type=Path, help="Directory containing JPEG files and captions.txt"
    )
    parser.add_argument(
        "-o",
        "--output-dir",
        type=Path,
        required=True,
        help="Directory to save processed files",
    )
    parser.add_argument(
            "--timezone", type=str, required=True, help="Timezone (e.g. +02:00 or Europe/Berlin)"
        )

    args = parser.parse_args()

    source_path = Path(args.source_dir)
    out_dir_path = Path(args.output_dir)
    out_dir_path.mkdir(parents=True, exist_ok=True)

    captions_file = source_path / "captions.txt"
    if not captions_file.exists():
        raise FileNotFoundError(f"captions.txt not found in {args.source_dir}")

    # 1. Parse and validate lexicographical order of captions file
    tz = ZoneInfo(args.timezone)
    metadata_list = parse_captions(captions_file, tz)
    filenames_in_captions = [m.filename for m in metadata_list]
    if filenames_in_captions != sorted(filenames_in_captions):
        raise ValueError("Files in captions.txt are not in lexicographical order.")

    # 2. Get actual JPEG files in source dir (sorted lexicographically)
    # We filter for .jpg and .jpeg (case insensitive)
    all_files = sorted([
        f for f in args.source_dir.iterdir() if f.suffix.lower() in (".jpg", ".jpeg")
    ])

    # Create metadata map for easy lookup
    meta_map: dict[str, ImageMetadata] = {m.filename: m for m in metadata_list}

    if not args.output_dir.exists():
        args.output_dir.mkdir(parents=True)

    current_datetime: datetime | None = None

    for img_path in all_files:
        fname = img_path.name
        meta = meta_map.get(fname)

        if not meta:
            warnings.warn(f"No caption found for {fname}, skipping.")  # noqa: B028
            continue

        # Check if file already has DateTimeOriginal
        # -s3 -DateTimeOriginal returns just the value if it exists
        existing_date = run_exiftool([
            "-s3",
            "-DateTimeOriginal",
            str(img_path),
        ]).strip()
        if existing_date:
            raise ValueError(f"File {fname} already has a 'date created' tag.")

        # Determine the date/time to use
        if meta.date:
            if current_datetime and meta.date < current_datetime:
                warnings.warn(f"Time moves backward for file {fname}.")  # noqa: B028
            current_datetime = meta.date
        else:
            # missing date
            if current_datetime is None:
                # First file must provide a date
                raise ValueError(
                    f"The first file ({fname}) must provide a date tag in captions.txt."
                )
            else:
                current_datetime = current_datetime + timedelta(minutes=1)

        # Format for EXIFtool: YYYY:MM:DD HH:MM:SS±HH:MM
        offset_secs = current_datetime.utcoffset()
        if offset_secs is None:
            raise ValueError(f"Naive datetime for {fname} — timezone required.")
        offset_hours = int(offset_secs.total_seconds()) // 3600
        offset_mins = (abs(int(offset_secs.total_seconds())) // 60) % 60
        sign = "+" if offset_secs.total_seconds() >= 0 else ""
        offset_str = f"{sign}{offset_hours:02d}:{offset_mins:02d}"
        exif_date = current_datetime.strftime("%Y:%m:%d %H:%M:%S") + " " + offset_str

        out_path = out_dir_path / fname

        # Use exiftool to write tags and copy to output folder
        # -o writes to the specified path instead of overwriting source
        run_exiftool([
            "-ImageDescription=" + meta.caption,
            "-DateTimeOriginal=" + exif_date,
            "-o",
            str(out_path),
            str(img_path),
        ])

        print(f"INFO: Processed {fname} -> {exif_date}")


if __name__ == "__main__":
    main()
