# too big for the GPU
# MODEL="deepseek-ai/DeepSeek-V4-Pro"
# MODEL_ARGS=(
# 	--max-model-len 131072
# 	--kv-cache-dtype fp8
# )

# too big for the GPU
# MODEL="deepseek-ai/DeepSeek-V4-Flash"
# MODEL_ARGS=(
# 	--max-model-len 131072
# 	--kv-cache-dtype fp8
# )

if test "$INSTANCE" = 0; then
    MODEL_ARGS=(
        --max-model-len 32768
        --reasoning-parser qwen3
        --tool-call-parser qwen3_coder
        --gpu-memory-utilization 0.40
        --max-num-batched-tokens 4096
        --block-size 32
        #--dtype fp8
        "Qwen/Qwen3.6-35B-A3B-FP8"
    )
fi

if test "$INSTANCE" = 1; then
    MODEL_ARGS=(
        # --max-model-len 16384
        --reasoning-parser qwen3
        --tool-call-parser qwen3_coder
        --gpu-memory-utilization 0.5
        --max-num-batched-tokens 4096
        #--dtype fp8
        "Qwen/Qwen3.6-27B-FP8"
    )
fi

ARGS=(
    --enable-sleep-mode
    --api-key "${API_KEYS[@]}"
    --host 127.0.0.1
    --port "$PORT"
    --max-num-seqs 4
    --enable-prefix-caching 
    --kv-cache-dtype fp8
    --enable-auto-tool-choice

    # Avoid, only use if OOM for prompts
    # --enable-chunked-prefill

    "${MODEL_ARGS[@]}"
)

vllm serve "${ARGS[@]}"

