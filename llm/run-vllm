#! /bin/bash

set -euo pipefail

INSTANCE="${1:-}"

if ! (test "$INSTANCE" = "0" || test "$INSTANCE" = 1); then
	echo "usage: $0 INSTANCE_NR (0 or 1)"
	exit 1
fi
PORT=$((8001 + INSTANCE))

export HF_TOKEN="$(cat $HOME/.huggingface-token)"

mapfile -t API_KEYS < <(grep -vE '^\s*(#|$)' $HOME/.vllm-api-keys )

source ~/vllm/.venv/bin/activate

# 80GB
