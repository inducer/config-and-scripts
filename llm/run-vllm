#! /bin/bash

set -euo pipefail

INSTANCE="${1:-}"

if ! (test "$INSTANCE" = "0" || test "$INSTANCE" = 1); then
	echo "usage: $0 INSTANCE_NR (0 or 1)"
	exit 1
fi
PORT=$((8001 + INSTANCE))

export HF_TOKEN="$(cat $HOME/.huggingface-token)"

source ~/vllm/.venv/bin/activate
# 80GB
#MODEL="google/gemma-4-31B-it"

# 24GB
# MODEL="google/gemma-4-E4B-it"
# MODEL_ARGS=(
# 	 --chat-template "$CHAT_TEMPLATE"
# 	$HOME/vllm/vllm-git/examples/tool_chat_template_gemma4.jinja
# )
# that chat template doesn't seem to fully fit

# too big for the GPU
# MODEL="deepseek-ai/DeepSeek-V4-Pro"
# MODEL_ARGS=(
# 	--max-model-len 131072
# 	--kv-cache-dtype fp8
# )

# too big for the GPU
# MODEL="deepseek-ai/DeepSeek-V4-Flash"
# MODEL_ARGS=(
# 	--max-model-len 131072
# 	--kv-cache-dtype fp8
# )

# --max-model-len 262144
# Too big of a KV cache

if test "$INSTANCE" = 0; then
	MODEL="Qwen/Qwen3.6-35B-A3B-FP8"
	MODEL_ARGS=(
	  --max-model-len 32768
	  --reasoning-parser qwen3
	  --enable-auto-tool-choice
	  --tool-call-parser qwen3_coder
	  --gpu-memory-utilization 0.45
	)
fi

# very slow
if test "$INSTANCE" = 1; then
	MODEL="Qwen/Qwen3.6-27B-FP8"
	MODEL_ARGS=(
	  --max-model-len 8192
	  --reasoning-parser qwen3
	  --enable-auto-tool-choice
	  --tool-call-parser qwen3_coder
	  --gpu-memory-utilization 0.45
	)
fi

# conserve memory, turn off
# --enable-prefix-caching

vllm serve \
	 --enable-sleep-mode \
	 --api-key "$( cat $HOME/.vllm-api-key )" \
	 --host 127.0.0.1 \
	 --port "$PORT" \
	 --max-num-seqs 2 \
	 --enable-chunked-prefill \
	 --dtype auto \
	 "${MODEL_ARGS[@]}" \
	 "$MODEL"
