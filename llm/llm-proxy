#!/usr/bin/env -S uv run --script
#
# /// script
# dependencies = [
#   "httpx",
#   "fastapi",
# ]
# ///

import itertools

import httpx
from fastapi import FastAPI, HTTPException, Request
from fastapi.responses import JSONResponse, StreamingResponse


app = FastAPI()

# -------------------------
# CONFIG
# -------------------------


class Backend:
    def __init__(self, name: str, base_url: str, api_key: str):
        self.name = name
        self.base_url = base_url.rstrip("/")
        self.api_key = api_key


# Example: two vLLM instances
BACKENDS: list[Backend] = [
    Backend("vllm-a", "http://10.0.0.1:8000", "UPSTREAM_KEY_A"),
    Backend("vllm-b", "http://10.0.0.2:8000", "UPSTREAM_KEY_B"),
]

# round-robin iterator
backend_cycle = itertools.cycle(BACKENDS)

# client API keys → allowed models / routing policy
CLIENT_KEYS: dict[str, dict] = {
    "client-key-1": {
        "allowed_models": ["model-a", "model-b"],
        "strategy": "round_robin",
    },
    "client-key-2": {
        "allowed_models": ["model-a"],
        "strategy": "sticky",  # example
        "backend": "vllm-a",
    },
}

# optional: model → backend mapping
MODEL_BACKEND_MAP = {
    # "model-a": "vllm-a",
    # "model-b": "vllm-b",
}


# -------------------------
# AUTH
# -------------------------

def authenticate(request: Request) -> dict:
    auth = request.headers.get("authorization")
    if not auth or not auth.startswith("Bearer "):
        raise HTTPException(status_code=401, detail="Missing API key")

    key = auth.split()[1]
    if key not in CLIENT_KEYS:
        raise HTTPException(status_code=403, detail="Invalid API key")

    return CLIENT_KEYS[key]


# -------------------------
# ROUTING
# -------------------------

def pick_backend(client_cfg: dict, model: str) -> Backend:
    # model-based routing first
    if model in MODEL_BACKEND_MAP:
        name = MODEL_BACKEND_MAP[model]
        for b in BACKENDS:
            if b.name == name:
                return b

    strategy = client_cfg.get("strategy", "round_robin")

    if strategy == "round_robin":
        return next(backend_cycle)

    if strategy == "sticky":
        name = client_cfg["backend"]
        for b in BACKENDS:
            if b.name == name:
                return b

    # fallback
    return next(backend_cycle)


# -------------------------
# CORE PROXY LOGIC
# -------------------------

async def stream_passthrough(
    client: httpx.AsyncClient,
    backend: Backend,
    path: str,
    headers: dict,
    body: bytes,
):
    url = f"{backend.base_url}{path}"

    # override auth header for upstream
    headers = dict(headers)
    headers["authorization"] = f"Bearer {backend.api_key}"

    async with client.stream(
        "POST",
        url,
        headers=headers,
        content=body,
        timeout=None,
    ) as resp:
        # pass through status + headers
        if resp.status_code != 200:
            text = await resp.aread()
            yield text
            return

        async for chunk in resp.aiter_bytes():
            yield chunk


@app.post("/v1/chat/completions")
async def chat_completions(request: Request):
    client_cfg = authenticate(request)

    body = await request.body()

    # parse just enough to route (do NOT mutate)
    try:
        json_body = await request.json()
    except Exception:
        raise HTTPException(status_code=400, detail="Invalid JSON")

    model = json_body.get("model")
    if not model:
        raise HTTPException(status_code=400, detail="Missing model")

    if model not in client_cfg["allowed_models"]:
        raise HTTPException(status_code=403, detail="Model not allowed")

    backend = pick_backend(client_cfg, model)

    headers = dict(request.headers)
    headers.pop("host", None)  # let httpx set it

    async with httpx.AsyncClient(http2=False) as client:
        # streaming or not?
        if json_body.get("stream", False):
            return StreamingResponse(
                stream_passthrough(
                    client,
                    backend,
                    "/v1/chat/completions",
                    headers,
                    body,
                ),
                media_type="text/event-stream",
            )
        else:
            url = f"{backend.base_url}/v1/chat/completions"
            headers["authorization"] = f"Bearer {backend.api_key}"

            resp = await client.post(
                url,
                headers=headers,
                content=body,
                timeout=None,
            )

            return JSONResponse(
                status_code=resp.status_code,
                content=resp.json(),
            )
