import asyncio
import secrets
import time
from contextlib import asynccontextmanager
from dataclasses import dataclass
from fnmatch import fnmatch
from typing import Generic, TypeAlias, TypeVar

import httpx
import typed_argparse as tap
import uvicorn
import yaml
from fastapi import FastAPI, HTTPException, Request
from fastapi.responses import JSONResponse, StreamingResponse
from pydantic import BaseModel, Field, field_validator, model_validator


"""
llm-proxy: A lightweight OpenAI-compatible proxy for routing requests to
(for example) multiple vLLM backends.

This script provides a FastAPI-based proxy that:
2. Filters available models based on the client's API key.
3. Routes requests to specific vLLM backends based on the requested model.
4. Supports streaming and non-streaming responses for Chat, Completions, and Embeddings.
"""


class Backend(BaseModel):
    base_url: str
    api_key: str | None = None

    @field_validator("base_url")
    @classmethod
    def strip_slash(cls, v: str) -> str:
        return v.rstrip("/")


class ClientConfig(BaseModel):
    allowed_models: list[str]  | None = None
    allowed_backends: list[str] | None = None


class ProxyConfig(BaseModel):
    listen_host: str = "127.0.0.1"
    listen_port: int = 8000
    backends: dict[str, Backend] = Field(min_length=1)
    client_keys: dict[str, ClientConfig]

    @model_validator(mode="after")
    def validate_allowed_backends(self):
        for client_cfg in self.client_keys.values():
            if client_cfg.allowed_backends is not None:
                for backend in client_cfg.allowed_backends:
                    if backend not in self.backends:
                        raise ValueError(f"Backend {backend} not found")
        return self


def authenticate(request: Request, config: ProxyConfig) -> ClientConfig:
    auth = request.headers.get("authorization")
    if not auth or not auth.startswith("Bearer "):
        raise HTTPException(status_code=401, detail="Missing API key")

    key = auth.split()[1]

    # To prevent timing attacks:
    # 1. Use secrets.compare_digest for constant-time comparison.
    # 2. Iterate through all keys to ensure the processing time is
    # independent of whether a match is found.
    matched_config = None
    for client_key, client_cfg in config.client_keys.items():
        if secrets.compare_digest(client_key, key):
            matched_config = client_cfg

    if matched_config is None:
        raise HTTPException(status_code=403, detail="Invalid API key")

    return matched_config


# -------------------------
# CORE PROXY LOGIC
# -------------------------

def add_auth_header(headers: dict[str, str], backend: Backend) -> dict[str, str]:
    return {
        **headers,
        **({"authorization": f"Bearer {backend.api_key}"}
            if backend.api_key is not None else {}),
    }


async def stream_passthrough(
    client: httpx.AsyncClient,
    backend: Backend,
    path: str,
    headers: dict,
    body: bytes,
):
    url = f"{backend.base_url}{path}"

    # override auth header for upstream
    headers = add_auth_header(headers, backend)

    async with client.stream(
        "POST",
        url,
        headers=headers,
        content=body,
        timeout=None,
    ) as resp:
        # pass through status + headers
        if resp.status_code != 200:
            yield await resp.aread()
            return

        async for chunk in resp.aiter_bytes():
            yield chunk


@dataclass
class ModelDesc:
    id: str
    backend: str
    data: dict[str, object]


T = TypeVar("T")


class ValueWithTTL(Generic[T]):
    ttl: float
    data: T | None
    expires_at: float

    def __init__(self, ttl: float):
        self.ttl = ttl
        self.data = None
        self.expires_at = 0

    def get(self):
        if self.data is not None and time.time() < self.expires_at:
            return self.data
        return None

    def set(self, value: T):
        self.data = value
        self.expires_at = time.time() + self.ttl


async def list_models_for_backend(
        config: ProxyConfig,
        backend_name: str,
        client: httpx.AsyncClient
    ) -> list[ModelDesc]:
    backend = config.backends[backend_name]
    url = f"{backend.base_url}/v1/models"
    headers = add_auth_header({}, backend)

    resp = await client.get(url, headers=headers, timeout=10.0)
    if resp.status_code != 200:
        return []
    data = resp.json()
    return [ModelDesc(id=model.get("id"), backend=backend_name, data=model)
        for model in data.get("data", []) if isinstance(model.get("id"), str)]


BackendToModelList: TypeAlias = dict[str, list[ModelDesc]]


async def list_models(config: ProxyConfig):
    async with httpx.AsyncClient(http2=False) as client:
        # Fetch from all backends in parallel
        responses = await asyncio.gather(*[
            list_models_for_backend(config, be_name, client)
            for be_name in config.backends], return_exceptions=True)

    return {
        be_name: [
            model
            for resp in responses
            if isinstance(resp, list)
            for model in resp
            if model.backend == be_name
        ]
        for be_name in config.backends
    }


async def list_models_cached(config: ProxyConfig):
    ttl_store_name = "list_models_ttl_store"
    ttl_store: ValueWithTTL[BackendToModelList] | None = getattr(
        config, ttl_store_name, None)
    if ttl_store is None:
        ttl_store = ValueWithTTL(ttl=60)
        object.__setattr__(config, ttl_store_name, ttl_store)

    result = ttl_store.get()
    if result is None:
        result = await list_models(config)
        ttl_store.set(result)

    return result


async def model_to_backends_cached(config: ProxyConfig) -> dict[str, set[str]]:
    return {
        backend: {model.id for model in models}
        for backend, models in (await list_models_cached(config)).items()
    }


def is_model_allowed(model: str, client_cfg: ClientConfig) -> bool:
    if client_cfg.allowed_models is None:
        return True
    return any(fnmatch(model, pat) for pat in client_cfg.allowed_models)


async def pick_backend(
        config: ProxyConfig,
        client_cfg: ClientConfig,
        model: str
) -> Backend:
    backends = (
        client_cfg.allowed_backends
        if client_cfg.allowed_backends is not None
        else config.backends)

    model_to_backends = await model_to_backends_cached(config)
    for be_name in backends:
        if model in model_to_backends[be_name]:
            return config.backends[be_name]

    raise HTTPException(status_code=500, detail="No backend found for model")


async def generic_proxy(request: Request, config: ProxyConfig, path: str):
    client_cfg = authenticate(request, config)

    body = await request.body()

    try:
        json_body = await request.json()
    except Exception as e:
        raise HTTPException(status_code=400, detail="Invalid JSON") from e

    model = json_body.get("model")
    if not model:
        raise HTTPException(status_code=400, detail="Missing model")

    if not is_model_allowed(model, client_cfg):
        raise HTTPException(status_code=403, detail="Model not allowed")

    backend = await pick_backend(config, client_cfg, model)

    headers = dict(request.headers)
    headers.pop("host", None)  # let httpx set it

    client = request.app.state.client

    if json_body.get("stream", False):
        return StreamingResponse(
            stream_passthrough(
                client,
                backend,
                path,
                headers,
                body,
            ),
            media_type="text/event-stream",
        )
    else:
        url = f"{backend.base_url}{path}"
        headers = add_auth_header(headers, backend)

        resp = await client.post(
            url,
            headers=headers,
            content=body,
            timeout=None,
        )

        return JSONResponse(
            status_code=resp.status_code,
            content=resp.json(),
        )


class Args(tap.TypedArgs):
    config: str = tap.arg(positional=True)


def add_proxy_route(app: FastAPI, path: str, config: ProxyConfig):
    @app.post(path)
    async def gen_proxy_route(request: Request):
        return await generic_proxy(request, config, path)


def run(args: Args):
    with open(args.config) as f:
        data = yaml.safe_load(f)
    config = ProxyConfig(**data)

    @asynccontextmanager
    async def lifespan(app: FastAPI):
        async with httpx.AsyncClient(http2=False) as client:
            app.state.client = client
            yield

    app = FastAPI(lifespan=lifespan)

    @app.get("/v1/models")
    async def list_models_inner(request: Request):
        all_models = await list_models(config)

        client_cfg = authenticate(request, config)
        filtered_models = [model
            for be_name in config.backends
            for model in all_models[be_name]
            if is_model_allowed(model.id, client_cfg)
        ]
        return {"object": "list", "data": [model.data for model in filtered_models]}

    for url in [
                "/v1/chat/completions",
                "/v1/completions",
                "/v1/embeddings",
            ]:
        add_proxy_route(app, url, config)

    uvicorn.run(app, host=config.listen_host, port=config.listen_port)


def main():
    tap.Parser(Args).bind(run).run()


if __name__ == "__main__":
    main()
